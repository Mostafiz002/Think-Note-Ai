datasource db {
  provider = "sqlite"
}

generator client {
  provider      = "prisma-client"
  output        = "../generated/prisma"
  moduleFormat  = "cjs"
}

model User {
  id    Int     @default(autoincrement()) @id
  name  String?
  email String  @unique
  password String
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}